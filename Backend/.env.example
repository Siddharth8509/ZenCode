PORT=3000
NODE_ENV=production

DB_URL=mongodb+srv://your-mongodb-uri
JWT_SECRET=replace_with_a_long_random_secret

# Comma-separated frontend URLs allowed by CORS.
FRONTEND_URL=http://localhost:5173,https://your-frontend.vercel.app
# Optional legacy alias still supported by the backend.
CLIENT_URL=http://localhost:5173

REDIS_USERNAME=default
REDIS_PASS=your_redis_password
REDIS_HOST=redis-15582.crce263.ap-south-1-1.ec2.cloud.redislabs.com
REDIS_PORT=15582

# Shared Gemini config for chat, aptitude generation, resume analyzer, and mock interview.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

RAPID_API_KEY=your_rapid_api_key

JUDGE0_SUBMIT_RETRIES=3
JUDGE0_MAX_POLL_RETRIES=18
JUDGE0_INITIAL_POLL_DELAY_MS=2000
JUDGE0_POLL_INTERVAL_MS=2000
JUDGE0_MAX_POLL_INTERVAL_MS=5000

# Resume Builder
RESUME_BUILDER_IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
RESUME_BUILDER_MONGODB_URI=mongodb+srv://optional-separate-resume-builder-db
